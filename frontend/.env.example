# ============================================
# Environment Variables Example
# ============================================
# Copy this file to .env for local development
# For production, .env.production is used automatically

# ============================================
# API Configuration
# ============================================

# Base URL for API requests (use relative path for same-origin)
# Development: http://localhost:8000/api (if Django runs separately)
# Production: /api (relative path when served from Django)
VITE_API_BASE_URL=/api

# Full API URL (only used in specific scenarios, mostly VITE_API_BASE_URL is used)
# Development: http://localhost:8000/api
# Production: (not needed, uses VITE_API_BASE_URL)
VITE_API_URL=http://localhost:8000/api

# ============================================
# Application Configuration
# ============================================

# Application name (displayed in UI)
VITE_APP_NAME=OHC-AHC Healthcare Portal

# Application version (for version display)
VITE_APP_VERSION=1.0.0

# Environment type (development, staging, production)
VITE_ENVIRONMENT=development

# ============================================
# Feature Flags
# ============================================

# Enable analytics tracking
VITE_ENABLE_ANALYTICS=false

# Enable error reporting (Sentry, etc.)
VITE_ENABLE_ERROR_REPORTING=false

# ============================================
# External Services (Optional)
# ============================================

# Sentry DSN for error tracking
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Google Analytics ID
# VITE_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# ============================================
# Development vs Production
# ============================================

# LOCAL DEVELOPMENT:
# - Copy this file to .env
# - Update VITE_API_URL to point to your local Django server
# - Run: npm run dev
# - Vite proxies /api requests to Django at http://localhost:8000

# PRODUCTION (AWS):
# - Uses .env.production automatically
# - No need to set .env file
# - Build with: npm run build
# - VITE_API_BASE_URL=/api uses relative path (no CORS!)

# ============================================
# Important Notes
# ============================================

# 1. All Vite env variables must start with VITE_ prefix
# 2. Variables are embedded at build time (not runtime)
# 3. Changes require rebuild: npm run build
# 4. Never commit .env file with real secrets!
